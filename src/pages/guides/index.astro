---
export const prerender = false;
import Base from '../../layouts/Base.astro';

const guides = [
  { slug: 'understanding-medicare-costs', title: 'Understanding Medicare Costs', description: 'How Medicare sets payment rates, what billed charges really mean, and why the gap between them matters for patients.' },
  { slug: 'most-expensive-procedures-in-america', title: 'Most Expensive Procedures in America', description: 'The costliest medical procedures ranked by Medicare payments and submitted charges, with state-by-state variation.' },
  { slug: 'why-healthcare-costs-vary-by-state', title: 'Why Healthcare Costs Vary by State', description: 'Geographic variation in Medicare payments explained — from cost-of-living adjustments to provider density.' },
  { slug: 'how-to-read-a-medical-bill', title: 'How to Read a Medical Bill', description: 'A practical guide to understanding every line on your medical bill, with real-world examples and common billing codes.' },
  { slug: 'hospital-markup-explained', title: 'Hospital Markup Explained', description: 'Why hospitals charge 3-10x what Medicare pays, how chargemasters work, and what it means for uninsured patients.' },
  { slug: 'negotiating-your-medical-bill', title: 'Negotiating Your Medical Bill', description: 'Proven scripts and tactics to reduce hospital and provider bills by 20-60% using cash prices, financial assistance, and your legal rights.' },
  { slug: 'hospital-price-transparency', title: 'Understanding Hospital Price Transparency', description: 'How the federal price transparency rule works, what machine-readable files contain, and how to use the data as a patient.' },
];
---

<Base
  title="Healthcare Cost Guides — PlainProcedure"
  description="Educational guides on Medicare costs, procedure pricing, medical billing, hospital price transparency, and healthcare cost variation across the US."
  breadcrumbs={[{ name: 'Home', href: '/' }, { name: 'Guides' }]}
>
  <div class="mx-auto max-w-4xl px-4 py-8 md:py-12">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-3">Healthcare Cost Guides</h1>
    <p class="text-gray-600 dark:text-gray-400 mb-4 max-w-2xl">
      In-depth resources to help you understand Medicare costs, medical billing, and healthcare price variation.
    </p>
    <p class="text-sm text-gray-500 dark:text-gray-500 mb-8">
      All guides reference CMS Medicare data covering 9,297 procedures across 56 states and territories.
    </p>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {guides.map(guide => (
        <a href={`/guides/${guide.slug}`} class="block p-6 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-sky-400 dark:hover:border-sky-500 transition-colors">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">{guide.title}</h2>
          <p class="text-sm text-gray-500 dark:text-gray-400">{guide.description}</p>
        </a>
      ))}
    </div>
  </div>
</Base>
