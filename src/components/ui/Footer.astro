---
const siteName = "PlainProcedure";
const currentYear = new Date().getFullYear();

const quickLinks = [
  { href: '/procedures/', label: 'Procedures' },
  { href: '/hospitals/', label: 'Hospitals' },
  { href: '/states/', label: 'States' },
  { href: '/search', label: 'Search' },
];

const legal = [
  { href: '/about', label: 'About' },
  { href: '/privacy', label: 'Privacy Policy' },
  { href: '/terms', label: 'Terms of Use' },
  { href: '/contact', label: 'Contact' },
];
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-card)] mt-auto">
  <div class="container py-16 md:py-20">
    <div class="grid grid-cols-2 md:grid-cols-12 gap-8">
      <div class="col-span-2 md:col-span-5 lg:col-span-4">
        <div class="font-semibold text-lg mb-3">{siteName}</div>
        <p class="text-sm text-[var(--color-muted)] max-w-xs leading-relaxed">
          Healthcare procedure costs in plain English. Compare Medicare payments and billed
          charges across 9,297 procedures, 5,426 hospitals, and 56 states.
        </p>
      </div>

      <div class="hidden md:block md:col-span-3 lg:col-span-4"></div>

      <div class="col-span-1 md:col-span-2 lg:col-span-2">
        <h3 class="text-xs font-semibold text-[var(--color-foreground)] uppercase tracking-wider mb-4">Explore</h3>
        <ul class="space-y-2.5">
          {quickLinks.map(item => (
            <li>
              <a href={item.href} class="text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="col-span-1 md:col-span-2 lg:col-span-2">
        <h3 class="text-xs font-semibold text-[var(--color-foreground)] uppercase tracking-wider mb-4">Legal</h3>
        <ul class="space-y-2.5">
          {legal.map(item => (
            <li>
              <a href={item.href} class="text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>


    <!-- Related Data Portals -->
    <div class="border-t border-[var(--color-border)] mt-8 pt-6">
      <h3 class="text-xs font-semibold text-[var(--color-foreground)] uppercase tracking-wider mb-3">Related Data</h3>
      <div class="flex flex-wrap gap-x-4 gap-y-1.5">
          <a href="https://plaindoctor.com" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors" target="_blank" rel="noopener">Provider Ratings</a>
          <a href="https://plainhospital.com" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors" target="_blank" rel="noopener">Hospital Quality</a>
          <a href="https://plainmeds.com" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors" target="_blank" rel="noopener">Drug Information</a>
          <a href="https://plainhealthplan.com" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors" target="_blank" rel="noopener">Health Insurance</a>
          <a href="https://plainhealthaccess.com" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors" target="_blank" rel="noopener">Shortage Areas</a>
      </div>
    </div>
    <div class="border-t border-[var(--color-border)] mt-12 pt-8 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-sm text-[var(--color-muted)]">
        &copy; {currentYear} {siteName}. All rights reserved.
      </p>
      <p class="text-xs text-[var(--color-muted)]">
        Data: CMS Medicare Physician &amp; Other Practitioners (2023)
      </p>
    </div>
  </div>
</footer>
